{
  "name": "matt-teach-web-app",
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n server,client -c cyan,magenta \"pnpm --filter teach-server dev\" \"pnpm --filter teach-client dev\"",
    "test": "pnpm --filter teach-server test",
    "typecheck": "concurrently \"pnpm --filter teach-server typecheck\" \"pnpm --filter teach-client typecheck\"",
    "sandcastle": "tsx .sandcastle/main.mts"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@ai-hero/sandcastle": "^0.10.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.22.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
